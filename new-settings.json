{
    // -------------------------------------------------------------------------
    // FILE MANAGEMENT
    // -------------------------------------------------------------------------
    "files.autoSave": "afterDelay",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,

    // -------------------------------------------------------------------------
    // FONT & TYPOGRAPHY
    // -------------------------------------------------------------------------
    "editor.fontFamily": "JetBrains Mono, 'Courier New', monospace",
    "editor.fontSize": 15,
    "editor.fontWeight": "300",
    "editor.fontLigatures": true,

    // -------------------------------------------------------------------------
    // CSS / SCSS / LESS VALIDATION
    // Disabled to suppress false-positive warnings for vendor-prefixed or
    // non-standard properties (e.g. Tailwind CSS directives).
    // -------------------------------------------------------------------------
    "css.validate": false,
    "scss.validate": false,
    "less.validate": false,

    // -------------------------------------------------------------------------
    // EDITOR APPEARANCE & BEHAVIOUR
    // -------------------------------------------------------------------------
    "editor.detectIndentation": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.cursorBlinking": "expand",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.codeActionsOnSave": {},
    "editor.renderControlCharacters": true,
    "editor.linkedEditing": true,
    "editor.indentSize": "tabSize",
    "editor.stickyScroll.enabled": false,
    "editor.formatOnSave": false,
    "breadcrumbs.enabled": true,

    // -------------------------------------------------------------------------
    // WINDOW
    // -------------------------------------------------------------------------
    "window.titleBarStyle": "custom",

    // -------------------------------------------------------------------------
    // WORKSPACE SECURITY
    // Workspace trust is fully disabled to allow unrestricted access
    // to files across all environments without interruption.
    // -------------------------------------------------------------------------
    "security.workspace.trust.untrustedFiles": "open",
    "security.workspace.trust.banner": "never",
    "security.workspace.trust.emptyWindow": false,
    "security.workspace.trust.enabled": false,
    "security.allowedUNCHosts": ["wsl.localhost"],

    // -------------------------------------------------------------------------
    // HTML FORMATTING
    // -------------------------------------------------------------------------
    "html.format.wrapLineLength": 0,
    "html.format.indentInnerHtml": true,

    // -------------------------------------------------------------------------
    // GIT
    // -------------------------------------------------------------------------
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.enableCommitSigning": true,
    "git.autoRepositoryDetection": "openEditors",

    // -------------------------------------------------------------------------
    // INTEGRATED TERMINAL
    // -------------------------------------------------------------------------
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.scrollback": 20000,
    "terminal.integrated.defaultProfile.windows": "Command Prompt",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.stickyScroll.enabled": false,

    // -------------------------------------------------------------------------
    // WORKBENCH — THEME & ICONS
    // -------------------------------------------------------------------------
    "workbench.colorTheme": "Monokai Pro (Filter Machine)",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.statusBar.visible": true,

    // -------------------------------------------------------------------------
    // WORKBENCH — EDITOR TABS & LAYOUT
    // -------------------------------------------------------------------------
    "explorer.compactFolders": false,
    "workbench.editor.enablePreview": true,
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.tabSizing": "shrink",
    "workbench.secondarySideBar.defaultVisibility": "hidden",

    // -------------------------------------------------------------------------
    // BACKGROUND IMAGES (vscode-background extension)
    // -------------------------------------------------------------------------
    "background.autoInstall": true,
    "background.editorBackgrounds": [
        "https://raw.githubusercontent.com/atikhasan392/.vscode/refs/heads/main/background/editor/1.jpg"
    ],
    "background.sidebarBackgrounds": [
        "https://raw.githubusercontent.com/atikhasan392/.vscode/refs/heads/main/background/sidebar/1.jpg"
    ],
    "background.panelBackgrounds": [
        "https://raw.githubusercontent.com/atikhasan392/.vscode/refs/heads/main/background/panel/1.jpg"
    ],

    // -------------------------------------------------------------------------
    // GITHUB COPILOT
    // -------------------------------------------------------------------------
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
        "php": false
    },

    // -------------------------------------------------------------------------
    // MATERIAL ICON THEME — GLOBAL APPEARANCE
    // -------------------------------------------------------------------------
    "material-icon-theme.opacity": 1,
    "material-icon-theme.saturation": 1,
    "material-icon-theme.folders.theme": "specific",
    "material-icon-theme.folders.color": "#fff",
    "material-icon-theme.files.color": "#fff",
    "material-icon-theme.hidesExplorerArrows": false,

    // -------------------------------------------------------------------------
    // MATERIAL ICON THEME — LARAVEL FILE ASSOCIATIONS
    // -------------------------------------------------------------------------
    "material-icon-theme.files.associations": {
        "*.blade.php": "laravel",
        "artisan": "laravel",
        ".env": "tune",
        "composer.json": "json",
        "composer.lock": "json",
        "package.json": "nodejs",
        "webpack.mix.js": "webpack",
        "vite.config.js": "vite",
        "phpunit.xml": "test-js"
    },

    // -------------------------------------------------------------------------
    // MATERIAL ICON THEME — LARAVEL FOLDER ASSOCIATIONS
    // -------------------------------------------------------------------------
    "material-icon-theme.folders.associations": {
        "bootstrap": "core",
        "Http": "global",
        "factories": "repository",
        "migrations": "class",
        "framework": "php",
        "storage": "server"
    },

    // -------------------------------------------------------------------------
    // EXTENSIONS — MISCELLANEOUS
    // -------------------------------------------------------------------------
    "liveServer.settings.donotShowInfoMsg": true,

    // -------------------------------------------------------------------------
    // PHP
    // -------------------------------------------------------------------------
    "php.validate.executablePath": "/usr/bin/php8.5"
}
